# Volcengine Ark (doubao-seed-2.0-pro)
# POST https://ark.cn-beijing.volces.com/api/v3/chat/completions
API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# IMPORTANT: 火山方舟控制台 -> API Key 管理 中创建（不要用 Sophnet/其他平台 Key）
# 使用 API_KEY=...；若系统里设置了 ARK_API_KEY 环境变量，会优先用本文件的 API_KEY
API_KEY=your_ark_api_key_here

# Models — doubao-seed-2.0-pro 接入点 ID
ROUTER_MODEL=ep-20260302092513-22vfv
INIT_MODEL=ep-20260302092513-22vfv
ANSWER_MODEL=ep-20260302092513-22vfv

# Content limits
MAX_FILE_CHARS=120000
MAX_TOKENS=4096
ANSWER_MAX_TOKENS=512
# 0 = 不限制回答汉字数；>0 时在 prompt 与兜底逻辑中截断
MAX_ANSWER_CHARS=0

USE_MAX_COMPLETION_TOKENS=0
USE_CONTENT_PARTS=0

# 回答阶段：将完整 knowledge.md 放入 system 提示，并按文档顺序附带插图（需 vision 模型）
ANSWER_WITH_IMAGES=1
# 0 = 不限制插图数量；>0 时最多发送 N 张
MAX_ANSWER_IMAGES=0

# 关闭思考模式（火山方舟：thinking.type=disabled）
DISABLE_THINKING=1
ENABLE_THINKING=0

# Initialization question count
MIN_ROUTE_QUESTIONS=50
MAX_ROUTE_QUESTIONS=100

# Max concurrent agent LLM calls during /ask (when multiple target_agents)
AGENT_MAX_WORKERS=8

# tests/dev
MOCK_LLM=0

# optional data paths (useful for tests / custom deployments)
# DATA_ROOT=D:/model_router
# AGENTS_CONFIG_PATH=D:/model_router/config/agents.json
# FILES_ROOT=D:/model_router/files
